{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://av-parfums-api.onrender.com/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://av-parfums-api.onrender.com/media/:path*"
    },
    { "source": "/((?!api/|media/|assets/).*)", "destination": "/index.html" }
  ]
}
