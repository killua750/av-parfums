# ======================================================================
# AV Parfums — environment template
# Copy to .env at the repo root (used by docker-compose and the backend).
# NEVER commit a real .env.
# ======================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Database (PostgreSQL 16) ---
# Bare-metal dev without Docker: leave unset to fall back to SQLite.
DATABASE_URL=postgres://av_parfums:av_parfums@localhost:5432/av_parfums
POSTGRES_DB=av_parfums
POSTGRES_USER=av_parfums
POSTGRES_PASSWORD=av_parfums

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
# True = run tasks synchronously (no worker needed, good for bare-metal dev)
CELERY_TASK_ALWAYS_EAGER=False

# --- CORS / CSRF (explicit origins, never *) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Auth ---
JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=7
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Email ---
DEFAULT_FROM_EMAIL=AV Parfums <no-reply@avparfums.dz>
ORDER_NOTIFICATION_EMAIL=ma.benkoua@gmail.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- Media storage (S3 optional; local MEDIA_ROOT when False) ---
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1

# --- Monitoring ---
SENTRY_DSN_BACKEND=
VITE_SENTRY_DSN=

# --- Frontend ---
VITE_API_URL=http://localhost:8000
